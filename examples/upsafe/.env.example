# upsafe configuration — copy to .env and edit. NEVER commit your real .env.

# REQUIRED. Static API key for the upload endpoint. The service refuses to start if unset.
# Generate one, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
UPSAFE_API_KEY=

# Data root holding the quarantine/ dir and upsafe.db. Default: ./upsafe-data
UPSAFE_DATA_ROOT=./upsafe-data

# Maximum accepted upload size, in bytes. Default: 10485760 (10 MiB)
UPSAFE_MAX_UPLOAD_BYTES=10485760

# Download token lifetime, in seconds. Default: 86400 (24 hours)
UPSAFE_TOKEN_TTL_SECONDS=86400

# Optional: restrict the allow-list to a subset of the built-in types
# (png, jpg, jpeg, gif, pdf, txt, csv). Comma-separated. Default: all of them.
# UPSAFE_ALLOWED_EXTENSIONS=png,pdf,txt

# Bind address for `python -m upsafe`. Defaults: 127.0.0.1 / 8000
UPSAFE_HOST=127.0.0.1
UPSAFE_PORT=8000

# Expose the interactive docs (/docs, /redoc) and OpenAPI schema (/openapi.json).
# OFF by default so production exposes no unauthenticated schema/UI. Set true for local dev.
UPSAFE_ENABLE_DOCS=false
